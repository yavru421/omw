@page "/"
@inject IJSRuntime JS
@inject NavigationManager NavManager

<div class="omw-card">
    <h2>OMW 📍</h2>
    <p style="color: #aaa;">Drop a pin and generate a request link.</p>

    @if (isLocating)
    {
        <p><em>Accessing GPS...</em></p>
    }
    else
    {
        <button class="btn-massive" @onclick="GenerateRequestLink">Get My Location Link</button>
    }

    @if (!string.IsNullOrEmpty(generatedLink))
    {
        <div class="link-box">@generatedLink</div>
        <p style="font-size: 0.9rem; margin-top: 12px; color: #aaa;">Copy this link and send it via SMS.</p>
    }
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert mt-3">@errorMessage</div>
    }
</div>

@code {
    private string generatedLink = "";
    private bool isLocating;
    private string errorMessage = "";

    private async Task GenerateRequestLink()
    {
        isLocating = true;
        errorMessage = "";
        try
        {
            var coords = await JS.InvokeAsync<OMW.Models.GpsCoordinates>("getDeviceLocation");
            generatedLink = $"{NavManager.BaseUri}respond?lat={coords.Latitude}&lng={coords.Longitude}";
        }
        catch (Exception ex)
        {
            errorMessage = "Could not access location. Please check your browser permissions.";
        }
        finally
        {
            isLocating = false;
        }
    }
}
