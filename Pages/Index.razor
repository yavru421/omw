@page "/"
@inject IJSRuntime JS
@inject NavigationManager NavManager

<div class="omw-card" style="padding: 30px;">
    <div style="margin-bottom: 24px;">
        <div style="font-size: 3rem; margin-bottom: 12px; filter: drop-shadow(0 4px 12px rgba(0, 122, 255, 0.35));">📍</div>
        <h1 style="font-size: 2.2rem; font-weight: 800; margin: 0; background: linear-gradient(135deg, #ffffff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Live OMW</h1>
        <p style="color: var(--text-secondary); margin: 8px 0 0 0; font-size: 0.95rem; font-weight: 400; line-height: 1.4;">
            Generate a secure, zero-liability tracking link to see when your guest is arriving.
        </p>
    </div>

    @if (isGenerating)
    {
        <button class="btn-massive" disabled style="opacity: 0.85;">
            <div class="spinner-omw"></div>
            Initializing Session...
        </button>
    }
    else if (string.IsNullOrEmpty(sessionId))
    {
        <button class="btn-massive" @onclick="GenerateLiveLink">
            <span>🚀</span> Create Live Link
        </button>
    }

    @if (!string.IsNullOrEmpty(sessionId))
    {
        <div class="link-box-container" style="animation: cardEntrance 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
            <div class="link-label">Your Live Tracking URL</div>
            <div class="link-box" @onclick="CopyUrlToClipboard">
                <span style="font-size: 0.8rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 240px;">@GetLink()</span>
                <span style="font-weight: 700; color: #00c6ff; font-size: 0.8rem; display: inline-flex; align-items: center; gap: 4px; flex-shrink: 0;">
                    @if (isCopied)
                    {
                        <span>✅ Copied</span>
                    }
                    else
                    {
                        <span>📋 Copy</span>
                    }
                </span>
            </div>
            <p style="font-size: 0.85rem; margin-top: 10px; color: var(--text-secondary); line-height: 1.4;">
                Send this to your guest. Leave this page open to see their ETA instantly!
            </p>
        </div>
        
        <div class="dashboard-panel" style="margin-top: 20px; padding: 20px; border-radius: 12px; background: rgba(0, 122, 255, 0.1); border: 1px solid rgba(0, 122, 255, 0.3);">
            <h3 style="margin-top: 0; color: #a5b4fc;">Live Status</h3>
            @if (string.IsNullOrEmpty(receivedEta))
            {
                <div style="display: flex; align-items: center; gap: 10px;">
                    <div class="spinner-omw" style="width: 20px; height: 20px; border-width: 2px;"></div>
                    <span style="color: var(--text-secondary);">Waiting for guest to respond...</span>
                </div>
            }
            else
            {
                <div style="font-size: 1.8rem; font-weight: 800; color: #2ea043; animation: pulse 2s infinite;">
                    @receivedEta
                </div>
            }
        </div>
    }
</div>

@code {
    private string sessionId = "";
    private bool isGenerating;
    private bool isCopied;
    private string receivedEta = "";
    private DotNetObjectReference<Index>? objRef;

    protected override void OnInitialized()
    {
        objRef = DotNetObjectReference.Create(this);
    }

    private async Task GenerateLiveLink()
    {
        isGenerating = true;
        try
        {
            // Call JS to create WebRTC session
            sessionId = await JS.InvokeAsync<string>("webrtc.initDashboard", objRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error generating live link: " + ex.Message);
        }
        finally
        {
            isGenerating = false;
        }
    }

    private string GetLink()
    {
        return $"{NavManager.BaseUri}respond?sessionId={sessionId}";
    }

    [JSInvokable]
    public void OnEtaReceived(string etaMessage)
    {
        receivedEta = etaMessage;
        StateHasChanged();
    }

    private async Task CopyUrlToClipboard()
    {
        if (string.IsNullOrEmpty(sessionId)) return;
        
        try
        {
            var success = await JS.InvokeAsync<bool>("copyToClipboard", GetLink());
            if (success)
            {
                isCopied = true;
                StateHasChanged();
                await Task.Delay(2000);
                isCopied = false;
                StateHasChanged();
            }
        }
        catch
        {
            // Fallback
        }
    }
    
    public void Dispose()
    {
        objRef?.Dispose();
    }
}
